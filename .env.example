# API base URL – required for Presence, Maps, Incidents REST endpoints.
# Use your deployed Cloud Functions URL (include /v1).
# Example for project "masscoms" in us-central1:
EXPO_PUBLIC_API_BASE_URL=https://us-central1-masscoms.cloudfunctions.net/api/v1

# WebSocket URL (optional, for real-time updates)
# EXPO_PUBLIC_WS_URL=wss://your-ws-url

# Skip biometrics (simulator / dev) – set to 1 to bypass Face ID gate
# EXPO_PUBLIC_SKIP_BIOMETRICS=1

# Use Firebase emulators when simulator can't reach production
# Run: firebase emulators:start --only auth,firestore
# Create test user at http://localhost:4000 (Auth tab)
# EXPO_PUBLIC_USE_AUTH_EMULATOR=1
# EXPO_PUBLIC_USE_FIRESTORE_EMULATOR=1
# EXPO_PUBLIC_EMULATOR_HOST=192.168.1.253  # Your Mac's IP (ifconfig | grep "inet ")
