# REST API base URL — required.
EXPO_PUBLIC_API_BASE_URL=https://admin.masscoms.com

# WebSocket URL — optional. Defaults to wss://admin.masscoms.com/ws if unset.
# EXPO_PUBLIC_WS_URL=wss://admin.masscoms.com/ws

# Set to 1 to bypass Face ID/biometrics gate (simulator / CI use only).
# EXPO_PUBLIC_SKIP_BIOMETRICS=1
